UMBRA__DATABASE__BACKEND=postgres
UMBRA__DATABASE__URL=postgres://umbra:umbra@localhost:5432/umbra
UMBRA__SERVER__PUBLIC_URL=http://localhost:8080
UMBRA__MIGRATIONS__AUTO_MIGRATE=false
UMBRA__AUTH__OPAQUE__SERVER_SETUP=
UMBRA__AUTH__OPAQUE__ALLOW_EPHEMERAL_SETUP=false

UMBRA_TEST_DATABASE_URL=postgres://umbra:umbra@localhost:5432/umbra_test

